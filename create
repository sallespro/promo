#!/usr/bin/env node

import fs from 'fs'
import path from 'path'
import { execSync } from 'child_process'
import { fileURLToPath } from 'url'
import { fetchContent, generateSite, parseFiles, writeFiles } from './lib/generate.js'

const __dirname = path.dirname(fileURLToPath(import.meta.url))

function parseArgs(argv) {
  const args = argv.slice(2)
  const opts = { prompt: '', url: '', out: '', lang: '', accent: '', model: 'claude-sonnet-4-6' }
  let i = 0
  while (i < args.length) {
    if      (args[i] === '--url')    opts.url    = args[++i]
    else if (args[i] === '--out')    opts.out    = args[++i]
    else if (args[i] === '--lang')   opts.lang   = args[++i]
    else if (args[i] === '--accent') opts.accent = args[++i]
    else if (args[i] === '--model')  opts.model  = args[++i]
    else if (!args[i].startsWith('--')) opts.prompt = args[i]
    i++
  }
  return opts
}

function readCriteria() {
  const p = path.join(__dirname, 'criteria.md')
  if (!fs.existsSync(p)) { console.error('❌ criteria.md not found next to the create CLI.'); process.exit(1) }
  return fs.readFileSync(p, 'utf8')
}

async function main() {
  const opts = parseArgs(process.argv)
  if (!opts.prompt && !opts.url) {
    console.log(`
Usage: ./create "<prompt>" [--url <url>] [--out <dir>] [--lang en|pt-BR] [--accent blue|green|amber|pink|teal]

Examples:
  ./create "AI consulting firm" --url https://ai.cloudpilot.com.br
  ./create "Health coaching for women" --accent green --lang pt-BR
  ./create "SaaS project management tool" --out myproject --lang en
`)
    process.exit(1)
  }

  console.log('\n🚀 Infoproduct Site Generator\n================================')
  const criteria = readCriteria()
  console.log('✓ Loaded criteria.md')

  const urlContent = await fetchContent(opts.url)
  const raw = await generateSite(opts, criteria, urlContent)

  let files
  try {
    files = parseFiles(raw)
  } catch (e) {
    console.error('❌ ' + e.message)
    fs.writeFileSync('create-debug.txt', raw)
    console.log('💾 Raw output saved to create-debug.txt')
    process.exit(1)
  }

  let outDir = opts.out
  if (!outDir) {
    const pkg = files.find(f => f.path === 'package.json')
    if (pkg) { try { outDir = JSON.parse(pkg.content).name || 'generated-site' } catch { outDir = 'generated-site' } }
    else outDir = 'generated-site'
  }

  const outPath = path.join(process.cwd(), outDir)
  if (fs.existsSync(outPath)) console.log(`\n⚠️  Directory "${outDir}" already exists. Files will be overwritten.`)
  else fs.mkdirSync(outPath, { recursive: true })

  writeFiles(files, outPath, { mkdirSync: fs.mkdirSync, writeFileSync: fs.writeFileSync, existsSync: fs.existsSync, join: path.join, dirname: path.dirname })

  console.log('\n📦 Installing dependencies...')
  try { execSync('npm install', { cwd: outPath, stdio: 'inherit' }); console.log('✓ Dependencies installed') }
  catch { console.warn('⚠️  npm install failed — run manually') }

  console.log('\n✅ Site generated!\n================================')
  console.log(`\n  cd ${outDir} && npm run dev`)
  console.log('\n  Frontend: http://localhost:5173')
  console.log('  Backend:  http://localhost:3001\n')
}

main().catch(e => { console.error('\n❌ Fatal error:', e.message); process.exit(1) })
